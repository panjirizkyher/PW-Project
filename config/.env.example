# SALIN ke file ".env" (jangan commit!). Semua key HANYA trade-permission, TANPA withdrawal.

# LLM (endpoint OpenAI-compatible, mis. Nous/Hermes)
LLM_API_KEY=sk-your-llm-key-here

# Telegram (opsional, untuk alert)
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=your_chat_id

# Exchange API — BUAT DENGAN IZIN TRADING SAJA, TANPA WITHDRAWAL.
# Paper mode TIDAK butuh ini. Live/testnet butuh.
EXCHANGE_API_KEY=your_exchange_key
EXCHANGE_API_SECRET=your_exchange_secret
